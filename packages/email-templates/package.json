{
  "name": "@cv/email-templates",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "default": "./dist/auth/index.js"
    },
    "./conformite": {
      "types": "./dist/conformite/index.d.ts",
      "default": "./dist/conformite/index.js"
    },
    "./mfa": {
      "types": "./dist/mfa/index.d.ts",
      "default": "./dist/mfa/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "lint": "biome check --error-on-warnings src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@react-email/components": "^0.0.31",
    "react": "^19.0.0",
    "react-email": "^3.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0"
  }
}
