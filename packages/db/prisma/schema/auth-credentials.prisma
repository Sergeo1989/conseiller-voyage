// Schéma Prisma — feature 002 (auth conseiller + admin).
//
// Étend auth.prisma (Auth.js v5) avec :
//   - Tokens à usage unique (vérif email, password reset, invitation admin)
//   - Audit immuable (sans FK — résolution H7 + ADR-0012)
//   - Lockout buckets (double bucket login : account + IP)
//   - Outbox courriels transactionnels (drainée par worker SES feature 003)
//
// Voir data-model.md pour la justification de chaque choix.

// ============================================================================
// EmailVerificationToken — TTL 24h, one-shot.
// ============================================================================

model EmailVerificationToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  // Identique au claim `nonce` du JWT envoyé par email. DELETE = invalidation.
  jwtNonce   String    @unique
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  consumedAt DateTime?

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_email_verification_tokens")
}

// ============================================================================
// PasswordResetToken — TTL 1h, one-shot, max 3 actifs/compte (FR-022).
// ============================================================================

model PasswordResetToken {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid
  jwtNonce      String    @unique
  createdAt     DateTime  @default(now())
  expiresAt     DateTime
  consumedAt    DateTime?
  // NOW() si un autre reset l'a invalidé (rate-limit 3 actifs).
  invalidatedAt DateTime?

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt, invalidatedAt])
  @@index([expiresAt])
  @@map("auth_password_reset_tokens")
}

// ============================================================================
// AdminInvitationToken — TTL 72h, one-shot.
// ============================================================================

model AdminInvitationToken {
  id                String    @id @default(uuid()) @db.Uuid
  // Email normalisé via normalizeEmail() (R9).
  targetEmail       String
  inviterUserId     String    @db.Uuid
  jwtNonce          String    @unique
  createdAt         DateTime  @default(now())
  expiresAt         DateTime
  consumedAt        DateTime?
  // Populated post-consumption pour traçabilité audit.
  createdAuthUserId String?   @db.Uuid

  // Relation inviter — SetNull pour permettre l'effacement Loi 25 du compte
  // de l'invitant sans casser la trace de l'invitation (H3).
  inviter AuthUser? @relation("AdminInviter", fields: [inviterUserId], references: [id], onDelete: SetNull)

  @@index([targetEmail])
  @@index([expiresAt])
  @@map("auth_admin_invitation_tokens")
}

// ============================================================================
// AuthAuditEvent — journal immuable, PAS de FK Prisma (H7 + ADR-0012).
// Résout la contradiction Principe IX (audit immuable, triggers Postgres
// rejettent UPDATE/DELETE/TRUNCATE) × Principe II (effacement Loi 25 doit
// pouvoir DELETE auth_users). Les colonnes actorUserId / targetUserId sont
// des UUID nus ; la corrélation post-effacement passe par actorEmailHash
// / targetEmailHash (SHA-256 base64 de l'email normalisé).
// ============================================================================

model AuthAuditEvent {
  id              String              @id @default(uuid()) @db.Uuid
  eventType       AuthAuditEventType
  actorUserId     String?             @db.Uuid
  targetUserId    String?             @db.Uuid
  actorEmailHash  String?             @db.VarChar(64)
  targetEmailHash String?             @db.VarChar(64)
  // IP abrégée /24 ou /48 via apps/api/src/common/actor-ip.util.ts (002a).
  actorIp         String?
  occurredAt      DateTime            @default(now())
  metadata        Json

  @@index([targetUserId, occurredAt(sort: Desc)])
  @@index([targetEmailHash, occurredAt(sort: Desc)])
  @@index([eventType, occurredAt(sort: Desc)])
  @@map("auth_audit_events")
}

enum AuthAuditEventType {
  signup
  email_verified
  login_success
  login_failed
  login_locked
  logout
  password_reset_requested
  password_reset_completed
  password_changed_self
  password_change_failed
  admin_bootstrap
  admin_invitation_sent
  admin_invitation_consumed
  admin_created_by_admin
}

// ============================================================================
// LoginLockoutBucket — double bucket atomique (login_account + login_ip).
// Pattern INSERT ON CONFLICT DO UPDATE de 002a (P0-2).
// ============================================================================

model LoginLockoutBucket {
  id            String           @id @default(uuid()) @db.Uuid
  kind          LoginLockoutKind
  // XOR : populated selon kind. Contrainte CHECK Postgres + index unique.
  accountId     String?          @db.Uuid
  ipHash        Bytes?
  failureCount  Int              @default(1)
  windowStartAt DateTime         @default(now())
  lastFailureAt DateTime         @default(now())

  @@unique([kind, accountId, ipHash], map: "login_lockout_key_unique")
  @@index([windowStartAt(sort: Desc)])
  @@map("auth_login_lockout_buckets")
}

enum LoginLockoutKind {
  login_account
  login_ip
}

// ============================================================================
// AuthOutboxEmail — drainée par worker SES (feature 003). Pattern 002a.
// Suppression à l'envoi confirmé pour ne pas conserver de PII (H4).
// ============================================================================

model AuthOutboxEmail {
  id              String            @id @default(uuid()) @db.Uuid
  recipientUserId String?           @db.Uuid
  // Toujours rempli pour permettre le drainage sans jointure (et pour
  // l'invitation admin où recipientUserId est NULL avant acceptation).
  recipientEmail  String
  templateKind    AuthEmailTemplate
  payload         Json
  createdAt       DateTime          @default(now())
  sentAt          DateTime?
  attempts        Int               @default(0)
  lastError       String?           @db.Text
  // T011 (feature 003) — expand compatible : backoff exponentiel
  // homogénéisé avec les autres outbox. Le worker 003
  // AuthOutboxDispatchWorker scanne avec sentAt IS NULL AND
  // (nextAttemptAt IS NULL OR nextAttemptAt <= now()).
  nextAttemptAt   DateTime?         @db.Timestamptz(6)

  recipientUser AuthUser? @relation(fields: [recipientUserId], references: [id], onDelete: SetNull)

  @@index([sentAt, createdAt])
  @@index([sentAt, nextAttemptAt])
  @@map("auth_outbox_emails")
}

enum AuthEmailTemplate {
  email_verification
  password_reset
  password_changed
  admin_invitation
}
