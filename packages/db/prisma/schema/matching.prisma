// Schéma Prisma du module matching — scoring conseiller × brief (top 3).
// Cf. specs/008-matching-scoring/data-model.md (4 tables + 3 enums)
//
// Phase 2 T011 : 4 modèles complets + 3 enums + indexes + contraintes CHECK
// + UNIQUE INDEX partiel idempotence briefId. Sera complété T012-T014 par
// les 3 migrations (init, audit append-only, anonymisation cascade).
//
// Conventions (héritées 001 / 008 / Principe V) :
//   - UUID v4 partout en `@db.Uuid`
//   - Tables préfixées `matching_*` pour matérialiser la frontière module
//     (`tools/check-module-boundaries.ts`)
//   - onDelete: Restrict par défaut — anonymisation Loi 25 nullifie les PII
//     via trigger Postgres cascade (ADR-0023) sans cascade silencieuse
//   - Audit log append-only dans `matching_audit_entries` (T013 trigger SQL)
//   - Outbox dédié dans `matching_outbox_entries` consommé par worker 003
//     étendu (T093, ADR-0024)

// =====================================================================
// Enums (3 nouveaux types Postgres scoped matching_*)
// =====================================================================

enum MatchingStatus {
  ok // top 3 complet
  partial // 1 ou 2 entries
  empty // 0 entries
}

enum MatchingAuditEventType {
  matching_computed
  matching_empty
  matching_partial
  matching_replay_ignored
  matching_recomputed
  matching_all_matches_revoked_detected
  matching_conseiller_address_missing
}

enum MatchingOutboxEventType {
  voyageur_brief_matched
  voyageur_brief_partially_matched
  voyageur_brief_unmatched
  voyageur_brief_all_matches_revoked
}

// ---------------------------------------------------------------------
// Enums feature 012 — leads (notifications conseiller + machine d'état)
// ---------------------------------------------------------------------

/// Machine d'état du lead (ADR-0025). Valeurs ASCII snake_case (les libellés
/// accentués FR-CA vivent dans l'i18n d'affichage). Terminaux : refuse,
/// reservation_confirmee, perdu.
enum LeadState {
  envoye
  vu
  accepte
  refuse
  devis_envoye
  reservation_confirmee
  perdu
}

/// Déclencheurs de transition (data-model §LeadAction).
enum LeadAction {
  marquer_vu
  accepter
  refuser
  marquer_devis_envoye
  marquer_reservation_confirmee
  marquer_perdu
  clore_systeme
}

/// Acteur d'une transition.
enum LeadTransitionActor {
  conseiller
  systeme
}

/// Canal d'acheminement de la notification conseiller (extensible).
enum LeadNotificationChannel {
  email
}

/// Statut d'acheminement de la notification conseiller.
enum LeadNotificationStatus {
  pending
  sent
  failed
  skipped_unverified
}

// =====================================================================
// Modèles
// =====================================================================

/// MatchingResult — trace d'un calcul de matching pour un brief, à un
/// instant donné. Une entrée active (supersededAt IS NULL) par briefId
/// via UNIQUE INDEX partiel — garantit l'idempotence FR-004.
model MatchingResult {
  id String @id @default(uuid()) @db.Uuid

  // briefId nullable post-anonymisation Loi 25 (trigger cascade ADR-0023).
  briefId String? @db.Uuid
  // FK uniquement INFORMATIVE — pas de FK Prisma car briefId peut être NULL
  // post-anonymisation et la table voyageur_briefs est dans le module intake.
  // L'invariant briefId présent ⇒ existe en intake est tenu par l'application.

  status                       MatchingStatus
  matchedCount                 Int            @db.SmallInt
  algorithmVersion             String         @db.VarChar(16)
  suggestedConseillerId        String?        @db.Uuid
  boostApplied                 Boolean        @default(false)
  computedAt                   DateTime
  supersededAt                 DateTime?
  supersededByMatchingResultId String?        @db.Uuid
  createdAt                    DateTime       @default(now())

  entries MatchingResultEntry[]
  leads   Lead[]

  // Index de file admin US5 extension de 008 (alertes WARN partial/empty)
  @@index([status, computedAt(sort: Desc)])
  // Lookup admin reverse — par briefId pour superseded chain
  @@index([briefId, createdAt(sort: Desc)])
  // L'UNIQUE INDEX partiel `idx_matching_results_brief_active` est créé
  // dans la migration (Prisma 5 supporte pas WHERE dans @@unique).
  @@map("matching_results")
}

/// MatchingResultEntry — une entrée du top 3 pour un MatchingResult.
/// 0 à 3 entries par MR (CHECK position IN (1,2,3) + UNIQUE
/// (matchingResultId, position) garantissent le plafond 3 strict — SC-003).
model MatchingResultEntry {
  id               String         @id @default(uuid()) @db.Uuid
  matchingResultId String         @db.Uuid
  matchingResult   MatchingResult @relation(fields: [matchingResultId], references: [id], onDelete: Cascade)

  position        Int      @db.SmallInt
  conseillerId    String   @db.Uuid
  scoreBrut       Decimal  @db.Decimal(5, 4)
  scoreFinal      Decimal  @db.Decimal(5, 4)
  scoreComponents Json     @db.JsonB
  boosted         Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@unique([matchingResultId, position])
  // Reverse lookup "mes affectations" côté feature 012 dashboard conseiller
  @@index([conseillerId, createdAt(sort: Desc)])
  @@map("matching_result_entries")
}

/// MatchingAuditEntry — trace append-only de chaque opération matching.
/// Trigger Postgres BEFORE UPDATE OR DELETE OR TRUNCATE installé en T013
/// (pattern hérité 001/008 `raise_append_only_error`).
/// Rétention 7 ans (constitution Cycle de vie et rétention des données).
model MatchingAuditEntry {
  id               String                 @id @default(uuid()) @db.Uuid
  briefId          String?                @db.Uuid
  matchingResultId String?                @db.Uuid
  eventType        MatchingAuditEventType
  payload          Json                   @db.JsonB
  idempotencyKey   String?                @db.VarChar(255)
  correlationId    String?                @db.VarChar(64)
  occurredAt       DateTime

  @@index([briefId, occurredAt(sort: Desc)])
  @@index([eventType, occurredAt(sort: Desc)])
  @@map("matching_audit_entries")
}

/// MatchingOutboxEntry — table outbox dédiée matching (R7 research /
/// ADR-0024). Consommée par OutboxPublisherJob (extension feature 003,
/// T093). Le UPDATE de publishedAt NULL → NOT NULL est le SEUL UPDATE
/// autorisé (trigger T013 conditionnel reject_unless_publishing).
model MatchingOutboxEntry {
  id             String                  @id @default(uuid()) @db.Uuid
  eventType      MatchingOutboxEventType
  payload        Json                    @db.JsonB
  idempotencyKey String                  @unique @db.VarChar(255)
  publishedAt    DateTime?
  createdAt      DateTime                @default(now())

  // Scan worker oldest-first
  @@index([createdAt(sort: Asc)])
  @@map("matching_outbox_entries")
}

// =====================================================================
// Feature 012 — Leads (notifications conseiller + machine d'état)
// =====================================================================

/// Lead — opportunité d'un conseiller sur un matching donné. Un lead par
/// couple (conseiller × MatchingResult) — UNIQUE garantit l'idempotence
/// (FR-003). `briefId` neutralisé (NULL) à l'anonymisation Loi 25 (cascade
/// trigger T009) ; `lead_transitions` jamais touché (audit préservé).
model Lead {
  id String @id @default(uuid()) @db.Uuid

  matchingResultId            String         @db.Uuid
  matchingResult              MatchingResult @relation(fields: [matchingResultId], references: [id], onDelete: Restrict)
  matchingResultEntryPosition Int            @db.SmallInt

  conseillerId String  @db.Uuid
  // briefId nullable post-anonymisation Loi 25 (trigger cascade T009).
  briefId      String? @db.Uuid

  // État dénormalisé (guard concurrence optimiste). Mis à jour
  // transactionnellement avec l'insert de transition (ADR-0025).
  currentState LeadState @default(envoye)

  scoreFinal  Decimal? @db.Decimal(5, 4)
  boosted     Boolean  @default(false)
  // Motif système (`re-matched`, `all_matches_revoked`) si clôture auto.
  closeReason String?  @db.VarChar(64)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transitions   LeadTransition[]
  notifications LeadNotificationOutbox[]

  // Idempotence FR-003 : 1 lead par (conseiller × matchingResult).
  @@unique([conseillerId, matchingResultId])
  @@index([briefId])
  // Sweeps / métriques par état.
  @@index([currentState])
  // Liste "mes leads" dashboard conseiller (014).
  @@index([conseillerId, createdAt(sort: Desc)])
  @@map("leads")
}

/// LeadTransition — historique immuable (append-only, trigger T008) des
/// changements d'état. `fromState` NULL pour la création initiale (→ envoye).
model LeadTransition {
  id     String @id @default(uuid()) @db.Uuid
  leadId String @db.Uuid
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Restrict)

  fromState  LeadState?
  toState    LeadState
  action     LeadAction
  actor      LeadTransitionActor
  // conseillerId si actor=conseiller ; null si systeme.
  actorId    String?             @db.Uuid
  // Motif (≤ 500 chars) — jamais de PII.
  reason     String?             @db.VarChar(500)
  occurredAt DateTime

  @@index([leadId, occurredAt(sort: Asc)])
  @@map("lead_transitions")
}

/// LeadNotificationOutbox — notification conseiller à acheminer (un par
/// destinataire, Principe X). L'adresse n'est jamais stockée : résolue au
/// moment de l'envoi via le module identité.
model LeadNotificationOutbox {
  id     String @id @default(uuid()) @db.Uuid
  leadId String @db.Uuid
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Restrict)

  conseillerId   String @db.Uuid
  // UNIQUE = `lead:{conseillerId}:{matchingResultId}` (idempotence FR-003).
  idempotencyKey String @unique @db.VarChar(255)

  channel   LeadNotificationChannel @default(email)
  status    LeadNotificationStatus  @default(pending)
  attempts  Int                     @default(0)
  lastError String?                 @db.Text

  createdAt DateTime  @default(now())
  sentAt    DateTime?

  // Scan worker des notifications à envoyer.
  @@index([status, createdAt(sort: Asc)])
  @@map("lead_notification_outbox")
}

/// ConsumedMatchingEvent — trace d'idempotence des événements bus déjà
/// traités (dédup at-least-once, ADR-0026).
model ConsumedMatchingEvent {
  idempotencyKey String   @id @db.VarChar(255)
  eventName      String   @db.VarChar(64)
  consumedAt     DateTime @default(now())

  @@map("consumed_matching_events")
}

// =====================================================================
// Feature 014 — Conversation conseiller ↔ voyageur (post-acceptation)
// ANTI-MARKETPLACE (ADR-0002) : AUCUN champ montant/prix/paiement/réservation.
// Un devis est UNIQUEMENT une ConversationAttachment opaque (binaire sur S3).
// =====================================================================

/// Auteur d'un message / destinataire d'une notification de conversation.
enum ConversationParticipant {
  conseiller
  voyageur
}

/// Statut d'acheminement d'une notification de message.
enum ConversationNotifStatus {
  pending
  sent
  failed
}

/// Conversation — fil entre un conseiller et le voyageur d'un lead ACCEPTÉ.
/// Un fil par lead (le lead identifie déjà le couple conseiller × brief).
/// Pas de relation Prisma vers Lead (découplage, cf. pattern audit no-FK du module).
model Conversation {
  id           String  @id @default(uuid()) @db.Uuid
  leadId       String  @unique @db.Uuid
  conseillerId String  @db.Uuid
  briefId      String? @db.Uuid // null si brief anonymisé (Loi 25)
  voyageurRef  String? @db.VarChar(255) // référence voyageur (neutralisable Loi 25)

  openedAt      DateTime  @default(now())
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  messages ConversationMessage[]

  @@index([conseillerId])
  @@index([briefId])
  @@map("conversations")
}

/// Message d'une conversation (texte ; body null après anonymisation Loi 25).
model ConversationMessage {
  id             String                  @id @default(uuid()) @db.Uuid
  conversationId String                  @db.Uuid
  conversation   Conversation            @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author         ConversationParticipant
  body           String?                 @db.Text
  idempotencyKey String                  @db.VarChar(255)
  createdAt      DateTime                @default(now())

  attachments   ConversationAttachment[]
  notifications ConversationNotificationOutbox[]

  @@unique([conversationId, idempotencyKey]) // idempotence d'envoi (FR-004)
  @@index([conversationId, createdAt(sort: Asc)])
  @@map("conversation_messages")
}

/// Pièce jointe — métadonnées seulement (binaire sur S3 ca-central-1).
/// AUCUN montant / champ transactionnel (ADR-0002).
model ConversationAttachment {
  id        String              @id @default(uuid()) @db.Uuid
  messageId String              @db.Uuid
  message   ConversationMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  fileName  String @db.VarChar(255)
  mimeType  String @db.VarChar(127)
  sizeBytes Int
  s3Key     String @db.VarChar(512)
  status    String @default("pending_upload") @db.VarChar(32) // pending_upload | ready

  createdAt DateTime  @default(now())
  deletedAt DateTime? // suppression Loi 25 (objet S3 supprimé, métadonnées d'audit conservées)

  @@index([messageId])
  @@map("conversation_attachments")
}

/// Outbox de notification — 1 entrée par destinataire (FR-003), drainée vers SES (003).
model ConversationNotificationOutbox {
  id        String              @id @default(uuid()) @db.Uuid
  messageId String              @db.Uuid
  message   ConversationMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  recipient      ConversationParticipant
  idempotencyKey String                  @unique @db.VarChar(255)
  status         ConversationNotifStatus @default(pending)
  attempts       Int                     @default(0)
  lastError      String?                 @db.Text

  createdAt DateTime  @default(now())
  sentAt    DateTime?

  @@unique([messageId, recipient]) // 1 notif/destinataire (FR-003)
  @@index([status, createdAt(sort: Asc)])
  @@map("conversation_notification_outbox")
}

/// Trace d'idempotence des événements consommés (ouverture de fil à l'acceptation).
model ConsumedConversationEvent {
  idempotencyKey String   @id @db.VarChar(255)
  consumedAt     DateTime @default(now())

  @@map("consumed_conversation_events")
}
