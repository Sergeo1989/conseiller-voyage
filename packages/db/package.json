{
  "name": "@cv/db",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "lint": "biome check --error-on-warnings src",
    "typecheck": "tsc --noEmit",
    "migrate": "prisma migrate dev --schema=./prisma/schema",
    "migrate:deploy": "prisma migrate deploy --schema=./prisma/schema",
    "generate": "prisma generate --schema=./prisma/schema",
    "studio": "prisma studio --schema=./prisma/schema",
    "seed:dev": "tsx prisma/seed.ts"
  },
  "prisma": {
    "schema": "./prisma/schema",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
}
