{
  "name": "@cv/legal",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./mdx-validation": {
      "types": "./src/mdx-validation.ts",
      "default": "./dist/mdx-validation.js"
    },
    "./anonymization": {
      "types": "./src/anonymization.ts",
      "default": "./dist/anonymization.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "lint": "biome check --error-on-warnings src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "ua-parser-js": "^2.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/ua-parser-js": "^0.7.39",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0"
  }
}
