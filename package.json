{
  "name": "conseiller-voyage",
  "version": "0.0.0",
  "private": true,
  "description": "Plateforme de mise en relation voyageur ↔ conseiller voyage vérifié (CCV/TICO)",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "biome check --error-on-warnings .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "db:migrate": "pnpm --filter @cv/db migrate",
    "db:generate": "pnpm --filter @cv/db generate",
    "db:studio": "pnpm --filter @cv/db studio",
    "db:seed:dev": "pnpm --filter @cv/db seed:dev",
    "docker:up": "docker compose -f docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f docker-compose.dev.yml down",
    "docker:restart": "docker compose -f docker-compose.dev.yml restart",
    "docker:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "docker:ps": "docker compose -f docker-compose.dev.yml ps",
    "docker:reset": "docker compose -f docker-compose.dev.yml down -v",
    "dev:up": "pnpm docker:up && pnpm db:migrate && pnpm dev",
    "check:boundaries": "tsx tools/check-module-boundaries.ts",
    "check:legal-access": "tsx tools/check-legal-acceptance-access.ts",
    "legal:verify": "tsx tools/check-legal-mdx.ts",
    "legal:seed": "tsx tools/seed-legal-documents.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "1.9.4",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@cv/db": "workspace:*",
    "@playwright/test": "^1.60.0",
    "@types/adm-zip": "^0.5.8",
    "@types/geojson": "^7946.0.16",
    "@types/proj4": "^2.19.0",
    "adm-zip": "^0.5.17",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "license-checker-rseidelsohn": "^4.4.2",
    "lint-staged": "^15.2.10",
    "proj4": "^2.20.8",
    "shapefile": "^0.6.6",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": ["biome check --write --no-errors-on-unmatched"]
  }
}
