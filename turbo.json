{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": ["tsconfig.base.json", ".env*"],
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "REDIS_URL",
    "AUTH_SECRET",
    "NEXTAUTH_URL",
    "NEXT_PUBLIC_SITE_URL",
    "NODE_ENV",
    "CI",
    "AWS_REGION",
    "AWS_S3_ENDPOINT",
    "AWS_S3_BUCKET_CONFORMITE",
    "AWS_S3_BUCKET_PROFILES",
    "AWS_KMS_PROFILES_KEY_ID",
    "CLOUDFRONT_PROFILES_DISTRIBUTION_ID",
    "CLOUDFRONT_PROFILES_PUBLIC_URL",
    "CV_SUGGESTED_COOKIE_SECRET",
    "CV_REVALIDATE_SECRET",
    "SENTRY_DSN",
    "OTEL_EXPORTER_OTLP_ENDPOINT",
    "OTEL_EXPORTER_OTLP_HEADERS",
    "OTEL_SERVICE_NAME"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^build", "^typecheck"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:unit": {
      "outputs": ["coverage/**"]
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
