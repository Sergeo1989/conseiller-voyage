{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3000/fr-CA",
        "http://localhost:3000/fr-CA/conseiller/conformite",
        "http://localhost:3000/fr-CA/conseiller/conformite/soumettre",
        "http://localhost:3000/fr-CA/admin/conformite",
        "http://localhost:3000/fr-CA/admin/conformite/permis"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "throttling": { "cpuSlowdownMultiplier": 1 },
        "extraHeaders": {
          "Cookie": "__Host-cv.session.token=__LIGHTHOUSE_SESSION_TOKEN__"
        }
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
        "interaction-to-next-paint": ["error", { "maxNumericValue": 200 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 300 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 1800 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    },
    "_comment": "T121 — Budgets cohérents avec Principe XII (CWV LCP/INP/CLS strictement dans les budgets, Lighthouse CI bloquant Perf >= 90, SEO >= 95, A11y >= 95). Le token de session est injecté par le job CI avant le run."
  }
}
