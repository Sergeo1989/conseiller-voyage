{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3000/fr",
        "http://localhost:3000/fr/conseiller/conformite",
        "http://localhost:3000/fr/conseiller/conformite/soumettre",
        "http://localhost:3000/fr/admin/conformite",
        "http://localhost:3000/fr/admin/conformite/permis",
        "http://localhost:3000/fr/mentions-legales",
        "http://localhost:3000/fr/cgu-voyageur",
        "http://localhost:3000/fr/cgu-conseiller",
        "http://localhost:3000/fr/confidentialite",
        "http://localhost:3000/fr/comment-ca-marche"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "throttling": { "cpuSlowdownMultiplier": 1 },
        "extraHeaders": {
          "Cookie": "__Host-cv.session.token=__LIGHTHOUSE_SESSION_TOKEN__"
        }
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
        "interaction-to-next-paint": ["error", { "maxNumericValue": 200 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 300 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 1800 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    },
    "_comment": "T121 (001) + T064 (004) — Budgets cohérents avec Principe XII (CWV LCP/INP/CLS strictement dans les budgets, Lighthouse CI bloquant Perf >= 90, SEO >= 95, A11y >= 95). 10 routes au total : 5 conformité existantes (001) + 5 nouvelles pages légales SSG (004). URLs en /fr/... (next-intl localePrefix mappe fr-CA → /fr). Le token de session est injecté par le job CI avant le run pour les pages authentifiées."
  }
}
