{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "outDir": "./dist",
    "rootDir": "./",
    "lib": ["ES2022"],
    "verbatimModuleSyntax": false,
    "isolatedModules": false
  },
  "include": ["bin/**/*.ts", "lib/**/*.ts"],
  "exclude": ["dist", "node_modules", "cdk.out"]
}
