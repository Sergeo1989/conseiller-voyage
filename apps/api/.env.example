# Template des variables d'environnement pour apps/api.
# Copier en `apps/api/.env` (gitignoré) puis remplir les valeurs.
# En production : injection via AWS Secrets Manager (ADR-0005).

NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=debug

# --- Persistance ---
DATABASE_URL=postgresql://cv_dev:cv_dev@localhost:5432/cv_dev
REDIS_URL=redis://localhost:6379

# --- AWS / LocalStack (dev) ---
AWS_REGION=ca-central-1
AWS_S3_ENDPOINT=http://localhost:4566
AWS_S3_BUCKET_CONFORMITE=cv-conformite-dev

# --- Idempotence (Principe X) ---
IDEMPOTENCY_KEY_TTL_SECONDS=604800

# --- Cache statut conformité (FR-022 de 001) ---
CONFORMITE_STATUS_CACHE_TTL_SECONDS=60
CONFORMITE_PUBSUB_CHANNEL=conformite.status.changed

# --- Observabilité (optionnelle en dev) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=
# SENTRY_DSN=
OTEL_SERVICE_NAME=cv-api-dev

# --- MFA (feature 005, Principe IX) ---
# Clé de chiffrement (KEK) du secret TOTP au repos.
# Format : 32 octets aléatoires encodés Base64 (= 44 caractères avec
# padding `=`).
# Générer pour dev local :
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Production : ARN AWS Secrets Manager
# arn:aws:secretsmanager:ca-central-1:<account>:secret:cv-mfa-kek
# (ADR-0010).
# REFUS automatique au démarrage si NODE_ENV=production et valeur de
# test bidon (32 octets de zéro) détectée.
MFA_KEK_BASE64=

# --- Auth (feature 002, Principe IX) ---
# Secret de signature des tokens JWT (email verif, password reset, admin
# invitation). 32 octets aléatoires base64.
# Générer pour dev :
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Production : ARN AWS Secrets Manager cv-auth-token-secret.
# REFUS automatique au démarrage si NODE_ENV=production et valeur de zéros.
AUTH_TOKEN_SECRET=

# Trust X-Forwarded-For pour l'audit IP. Dev : false. Prod : true.
TRUSTED_PROXY_HEADERS=false
